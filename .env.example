# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here   # get this by messaging @userinfobot

# ClickUp
CLICKUP_API_TOKEN=your_clickup_api_token_here  # User Settings → Apps → API Token
CLICKUP_TEAM_ID=your_team_id_here              # found in ClickUp URL: app.clickup.com/{TEAM_ID}/...
CLICKUP_JOSH_USER_ID=your_clickup_user_id      # Settings → Profile → scroll to bottom for User ID

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Default model is claude-opus-4-6 (strongest). Override if your API key/plan does not include it.
# ANTHROPIC_MODEL=claude-opus-4-6
# Optional: max characters of transcript sent to Claude for analysis (full text still goes to ClickUp doc)
# ANTHROPIC_MAX_TRANSCRIPT_CHARS=400000

# Mark done (/mark_complete) — optional hints if a list has multiple “closed” columns
# (the bot loads each task’s list and uses the list’s closed status from the API)
# CLICKUP_DONE_STATUS=complete
# CLICKUP_DONE_STATUS_ALT=Complete,closed

# Compose (/compose) — max docs considered when picking a source (default 80)
# COMPOSE_MAX_CANDIDATES=80
# Max characters of source doc markdown sent to Claude (default 120000)
# COMPOSE_MAX_SOURCE_CHARS=120000

# Query (/query) — tasks + doc excerpts (defaults: 15 docs, 8000 chars each; tasks cap below)
# QUERY_MAX_DOCS=15
# QUERY_MAX_CHARS_PER_DOC=8000
# QUERY_MAX_TASKS=220

# Ask (/ask) — max tasks included in the snapshot sent to Claude (default 220)
# ASK_MAX_TASKS=220

# Focus (/focus) — AI ranking across all spaces (default: all open tasks, every assignee)
# Max tasks forwarded to Claude after priority+staleness sort (default 150)
# FOCUS_MAX_TASKS_FOR_AI=150
# Optional: limit to tasks assigned to CLICKUP_JOSH_USER_ID only
# FOCUS_ASSIGNEE_ONLY=1

# App
PORT=3000
# Cloud: set to your public origin only (no path, trailing slash OK). Startup registers Telegram webhook at {WEBHOOK_URL}/webhook
# Example: https://ddc-clickup-bot-production.up.railway.app
# Leave empty for local dev — bot uses Telegram long polling.
WEBHOOK_URL=
TIMEZONE=America/Mexico_City
