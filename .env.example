# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here   # get this by messaging @userinfobot

# ClickUp
CLICKUP_API_TOKEN=your_clickup_api_token_here  # User Settings → Apps → API Token
CLICKUP_TEAM_ID=your_team_id_here              # found in ClickUp URL: app.clickup.com/{TEAM_ID}/...
CLICKUP_JOSH_USER_ID=your_clickup_user_id      # Settings → Profile → scroll to bottom for User ID

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App
PORT=3000
WEBHOOK_URL=https://your-railway-app.up.railway.app   # update after Railway deploy
TIMEZONE=America/Mexico_City
