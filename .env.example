# ── Copy this file to `.env` and replace placeholder values. ──
# `.env` stays gitignored; Railway: Settings → Variables (paste each line or bulk import).

# ── Telegram (required) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── ClickUp (required) ──
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=
CLICKUP_JOSH_USER_ID=

# ── Anthropic (required for meeting / ask / query / compose / focus) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TRANSCRIPT_CHARS=400000

# ── ClickUp mark-complete overrides (optional) ──
CLICKUP_DONE_STATUS=
CLICKUP_DONE_STATUS_ALT=

# ── Compose (/compose) ──
COMPOSE_MAX_CANDIDATES=80
COMPOSE_MAX_SOURCE_CHARS=120000

# ── Query (/query) ──
QUERY_MAX_DOCS=15
QUERY_MAX_CHARS_PER_DOC=8000
QUERY_MAX_TASKS=220

# ── Ask (/ask) ──
ASK_MAX_TASKS=220

# ── Focus (/focus) ──
FOCUS_MAX_TASKS_FOR_AI=150
FOCUS_ASSIGNEE_ONLY=

# ── APS GitHub ingestion (only used when spaceName === "APS") ──
# Personal Access Token with repo:contents:write scope to the aps-master repo.
# Fine-grained PAT recommended; scope to the single repo.
GITHUB_TOKEN=
GITHUB_REPO=joshuaboike/aps-master
GITHUB_BRANCH=main
GITHUB_COMMIT_AUTHOR_NAME=clickup-bot
GITHUB_COMMIT_AUTHOR_EMAIL=clickup-bot@ddc.local

# ── App / hosting ──
PORT=3000
LISTEN_HOST=0.0.0.0
# Must be HTTPS origin, e.g. https://clickup-bot-production-xxxx.up.railway.app (no /webhook)
WEBHOOK_URL=
TIMEZONE=America/Mexico_City

# Meeting paste: wait N ms after /done (and reset on each new chunk) so Telegram can deliver split pastes. 0 = instant old behavior.
# MEETING_DONE_DEBOUNCE_MS=3500
